#!/bin/bash
# Factory Toolbox: Scan for existing artifacts
[ ! -d "factory" ] && exit 0
artifacts=$(find factory -maxdepth 2 -name "*.md" 2>/dev/null | sed 's|factory/||;s|/.*||' | sort -u | paste -sd ',' - | sed 's/,/, /g')
[ -z "$artifacts" ] && exit 0
python3 -c "
import json
print(json.dumps({'additional_context': f'[Factory] Artifacts found: {\"$artifacts\"}. Run /factory-<skill> to continue.'}))
"
